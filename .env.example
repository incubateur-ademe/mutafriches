# ===========================================
# Mutafriches - Variables d'environnement
# ===========================================
# Ce fichier est copié vers apps/api/.env par `pnpm setup`

# Application
PORT=3000
NODE_ENV=development

# Base de donnees PostgreSQL (Docker local)
DB_HOST=localhost
DB_PORT=5432
DB_USER=mutafriches_user
DB_PASSWORD=mutafriches_password
DB_NAME=mutafriches

# Origines autorisees (CORS) - separees par des virgules
# ALLOWED_ORIGINS=http://localhost:5173
# ALLOWED_INTEGRATOR_ORIGINS=

# Metabase (optionnel - embedding dashboard statistiques)
# METABASE_SITE_URL=
# METABASE_SECRET_KEY=
# METABASE_DASHBOARD_ID=3
