# Application
PORT=3000
NODE_ENV=development

# Base de données PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=mutafriches_user
DB_PASSWORD=mutafriches_password
DB_NAME=mutafriches

# ALLOWED_ORIGINS - Liste des origines autorisées pour le guard CORS, séparées par des virgules
ALLOWED_ORIGINS=https://mutafriches.incubateur.ademe.dev,https://mutafriches.beta.gouv.fr,http://localhost:5173

# Metabase (embedding du dashboard statistiques)
METABASE_SITE_URL=https://metabase.mutafriches.beta.gouv.fr
METABASE_SECRET_KEY=
METABASE_DASHBOARD_ID=3

# Envoi d'emails - bascule automatique (cf. ADR-0017) :
#   - local/dev OU BREVO_API_KEY absente -> SMTP/MailHog (pnpm mail:start, UI http://localhost:8026)
#   - staging/prod avec BREVO_API_KEY -> API HTTP Brevo
SMTP_HOST=localhost
SMTP_PORT=1026
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Cle API Brevo (staging/prod). Absente en local -> MailHog.
BREVO_API_KEY=
MAIL_SENDER_EMAIL=contact@mutafriches.beta.gouv.fr
MAIL_SENDER_NAME=Mutafriches
# Adresse de reponse (Reply-To). Defaut : MAIL_SENDER_EMAIL.
EMAIL_REPLY_TO=
# Redirection staging : reecrit TOUS les destinataires vers cette boite de test.
# INTERDITE en production, restreinte aux domaines beta.gouv.fr / incubateur.ademe.dev.
EMAIL_DEV_INBOX=
# Base des liens dans les emails
APP_BASE_URL=https://mutafriches.beta.gouv.fr
# Adresse de l'equipe notifiee a chaque demande de contact multisites
CONTACT_NOTIFICATION_EMAIL=contact@mutafriches.beta.gouv.fr
# Lien Metabase listant les demandes de contact (inclus dans l'email de notification)
CONTACT_DASHBOARD_URL=https://metabase.mutafriches.beta.gouv.fr/dashboard/10-demandes-de-contact
