# ===========================================
# Mutafriches UI - Variables d'environnement (Vite)
# ===========================================
# Toutes les variables exposées au front doivent être préfixées par VITE_.

# URL de l'API (défaut : http://localhost:3000 en dev, origine courante en prod)
# VITE_API_URL=http://localhost:3000

# Affiche le panneau de diagnostic (dev/staging)
# VITE_SHOW_DEBUG_PANEL=true

# Affiche la page de test « Comparaison Cartofriches » (masquée par défaut hors dev)
# VITE_SHOW_COMPARAISON_CARTOFRICHES=true

# Calendrier ZCal embarqué (prise de rendez-vous multisites)
# URL de réservation brute (sans paramètres : le script d'embed les ajoute)
# Défaut : calendrier de l'équipe Mutafriches (https://zcal.co/i/D0NODYSy)
# VITE_ZCAL_URL=https://zcal.co/i/D0NODYSy
